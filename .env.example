# .env 파일 (실제 값으로 교체 필요)
DB_SERVER=kevinsaem.com,1433
DB_NAME=kevinsaem_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
JWT_SECRET=change-this-to-random-64-char-secret-key
JWT_EXPIRE_MINUTES=30
KAKAO_API_KEY=your_kakao_api_key
KAKAO_SENDER_KEY=your_kakao_sender_key
ALLOWED_ORIGINS=["http://localhost:8000","https://booking.kevinsaem.com"]
